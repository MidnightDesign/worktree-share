#!/usr/bin/env bash
# Automatically symlink shared worktree files into the current worktree on checkout.

# Only act on branch checkouts, not file checkouts
[[ "$3" == "1" ]] || exit 0

git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || exit 0

shared_dir="$git_common_dir/share"
[[ -d "$shared_dir" ]] || exit 0

worktree_root=$(git rev-parse --show-toplevel)

while IFS= read -r -d '' file; do
    rel="${file#"$shared_dir"/}"
    target="$worktree_root/$rel"
    mkdir -p "$(dirname "$target")"
    ln -sf "$file" "$target"
done < <(find "$shared_dir" -type f -print0)
