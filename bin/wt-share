#!/usr/bin/env bash
# Apply shared worktree files to all existing linked worktrees of the current repo.
# Usage: wt-share

git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || {
    echo "error: not in a git repository" >&2
    exit 1
}

shared_dir="$git_common_dir/share"

if [[ ! -d "$shared_dir" ]]; then
    echo "No shared files found."
    echo "Create $shared_dir and put your files there."
    echo "They will be symlinked into every linked worktree automatically."
    exit 0
fi

mapfile -d '' files < <(find "$shared_dir" -type f -print0)

if [[ ${#files[@]} -eq 0 ]]; then
    echo "No files in $shared_dir"
    exit 0
fi

applied=0

while IFS= read -r worktree_path; do
    echo "$worktree_path"
    for file in "${files[@]}"; do
        rel="${file#"$shared_dir"/}"
        target="$worktree_path/$rel"

        if [[ -e "$target" || -L "$target" ]]; then
            # Already a symlink pointing to the same source — skip
            if [[ -L "$target" ]] && [[ "$(readlink -f "$target")" == "$(readlink -f "$file")" ]]; then
                echo "  -> $rel (unchanged)"
                continue
            fi

            # Different: compare content and ask before overwriting
            if ! diff -q "$target" "$file" &>/dev/null; then
                printf "  %s already exists and differs. Override? [y/N] " "$rel"
                read -r answer </dev/tty
                [[ "$answer" =~ ^[Yy]$ ]] || { echo "  -> $rel (skipped)"; continue; }
            fi
        fi

        mkdir -p "$(dirname "$target")"
        ln -sf "$file" "$target"
        echo "  -> $rel"
    done
    (( applied++ ))
done < <(git worktree list --porcelain | awk '$1 == "worktree" { print $2 }')

if [[ $applied -eq 0 ]]; then
    echo "No linked worktrees found."
fi
